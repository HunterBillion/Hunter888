# Database
DATABASE_URL=postgresql+asyncpg://trainer:trainer_pass@localhost:5432/trainer_db
DATABASE_URL_SYNC=postgresql://trainer:trainer_pass@localhost:5432/trainer_db
POSTGRES_USER=trainer
POSTGRES_PASSWORD=trainer_pass
# Имя БД в Docker; в DATABASE_URL путь после :5432/ должен совпадать (не путать с POSTGRES_USER)
POSTGRES_DB=trainer_db

# Redis (REDIS_PASSWORD used by docker-compose for Redis auth)
REDIS_PASSWORD=redis_secret_pass
REDIS_URL=redis://:redis_secret_pass@localhost:6379/0

# JWT (CHANGE IN PRODUCTION — use: openssl rand -hex 32)
JWT_SECRET=change-me-in-production-use-openssl-rand-hex-32
JWT_ALGORITHM=HS256
# S4-01: Reduced from 30 to 5 for security
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=5
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# LLM — Priority chain: Local Gemma (Mac Mini) → Gemini Cloud → Claude → OpenAI → Scripted
LLM_PRIMARY_MODEL=gemma-3-4b-it
LLM_FALLBACK_MODEL=gpt-4o-mini
LLM_TIMEOUT_SECONDS=20
LLM_MAX_HISTORY_MESSAGES=20

# Local LLM — Gemma 4 E2B on Mac Mini M2 via Ollama (PRIMARY, unlimited RPM)
# Start Ollama on Mac Mini: OLLAMA_HOST=0.0.0.0 ollama serve
LOCAL_LLM_URL=http://192.168.31.35:11434/v1
LOCAL_LLM_MODEL=gemma4:e2b
LOCAL_LLM_ENABLED=true
LOCAL_LLM_API_KEY=ollama

# Gemini Direct API (FALLBACK — cloud, free 15 RPM, 1500 req/day)
# Get free key: https://aistudio.google.com/apikey
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# Cloud fallbacks (optional)
CLAUDE_API_KEY=
OPENAI_API_KEY=

# Concurrency (max parallel LLM calls — prevents rate limit with 10+ users)
MAX_CONCURRENT_LLM_CALLS=5

# Gemini Embeddings (get free key: https://aistudio.google.com/apikey)
GEMINI_EMBEDDING_API_KEY=
GEMINI_EMBEDDING_MODEL=gemini-embedding-001

# ElevenLabs TTS (natural AI voice for client character)
# Get key: https://elevenlabs.io/app/settings/api-keys
# Pick Russian voices: https://elevenlabs.io/text-to-speech/russian
# Plans: Free (10k chars) / Starter $5 (30k chars) / Creator $22 (100k chars)
# Voices: comma-separated IDs — each session picks one, so AI-clients sound different
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_IDS=voice1,voice2,voice3
ELEVENLABS_MODEL=eleven_v3
ELEVENLABS_TIMEOUT_SECONDS=10
ELEVENLABS_ENABLED=false

# STT (not needed for pilot — uses Web Speech API in browser)
WHISPER_URL=http://localhost:8001
WHISPER_MODEL=large-v3
WHISPER_LANGUAGE=ru

# App (for Docker build: set NEXT_PUBLIC_* before `docker compose build web`)
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_WS_URL=ws://localhost:8000
APP_ENV=development
APP_DEBUG=true
APP_HOST=0.0.0.0
APP_PORT=8000
FRONTEND_URL=http://localhost:3000
CORS_ORIGINS=http://localhost:3000

# Rate Limits
MAX_SESSIONS_PER_DAY=10
MAX_SESSION_DURATION_MINUTES=30
MAX_MESSAGES_PER_SESSION=200

# SMTP (for password reset emails)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM_NAME=Hunter888
SMTP_USE_TLS=true

# Web Push (generate: npx web-push generate-vapid-keys)
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@hunter888.ru

# Gemini RPM limit (free tier: 15, paid: 360+)
GEMINI_RPM_LIMIT=15

# OAuth — Google (https://console.cloud.google.com/apis/credentials)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3000/auth/callback

# OAuth — Yandex (https://oauth.yandex.ru/client/new)
YANDEX_CLIENT_ID=
YANDEX_CLIENT_SECRET=
YANDEX_REDIRECT_URI=http://localhost:3000/auth/callback

# Payment — YooKassa (https://yookassa.ru/my/shop-settings)
PAYMENT_PROVIDER=yookassa
YOOKASSA_SHOP_ID=
YOOKASSA_SECRET_KEY=
# Payment — Stripe (https://dashboard.stripe.com/apikeys)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
PAYMENT_RETURN_URL=http://localhost:3000/subscription/success
