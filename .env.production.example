# ╔══════════════════════════════════════════════════════════════════════╗
# ║  Hunter888 — Production Environment Template                        ║
# ║  Copy to .env.production and fill in all values.                    ║
# ║  NEVER commit this file with real credentials.                      ║
# ╚══════════════════════════════════════════════════════════════════════╝

# ── Database ──────────────────────────────────────────────────────────
# Generate password: openssl rand -base64 24
POSTGRES_USER=trainer
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD
POSTGRES_DB=trainer_db
DATABASE_URL=postgresql+asyncpg://${POSTGRES_USER}:${POSTGRES_PASSWORD}@postgres:5432/${POSTGRES_DB}

# ── Redis ─────────────────────────────────────────────────────────────
# Generate password: openssl rand -base64 24
REDIS_PASSWORD=CHANGE_ME_STRONG_PASSWORD
REDIS_URL=redis://:${REDIS_PASSWORD}@redis:6379/0

# ── JWT ───────────────────────────────────────────────────────────────
# Generate secret: openssl rand -hex 32
JWT_SECRET=CHANGE_ME_GENERATE_WITH_OPENSSL
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# ── LLM ──────────────────────────────────────────────────────────────
# 2026-04-21 unified: only gpt-5.4 (primary) + claude-opus-4.7 (fallback).
# Mini/nano/older banned per owner directive. Both via navy.api proxy.
LLM_PRIMARY_MODEL=gpt-5.4
LLM_FALLBACK_MODEL=claude-opus-4.7
LLM_TIMEOUT_SECONDS=15
LLM_MAX_HISTORY_MESSAGES=20
MAX_CONCURRENT_LLM_CALLS=5

# ── API Keys (store in secrets manager, inject via CI/CD) ─────────────
# Gemini: https://aistudio.google.com/apikey
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
GEMINI_EMBEDDING_API_KEY=
GEMINI_EMBEDDING_MODEL=gemini-embedding-001

# ElevenLabs TTS: https://elevenlabs.io/app/settings/api-keys
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_IDS_MALE=
ELEVENLABS_VOICE_IDS_FEMALE=
ELEVENLABS_MODEL=eleven_v3
ELEVENLABS_TIMEOUT_SECONDS=10
ELEVENLABS_ENABLED=true

# Cloud fallbacks
CLAUDE_API_KEY=
OPENAI_API_KEY=

# ── Navy.api — recommended unified gateway (2026-04-21) ──────────────
# Navy.api proxies OpenAI, Anthropic, ElevenLabs, Gemini and more behind
# one OpenAI-compatible endpoint (/v1/chat/completions, /v1/audio/speech,
# /v1/embeddings, /v1/audio/transcriptions). One key for everything.
#
# LLM (roleplay AI):
LOCAL_LLM_URL=https://api.navy/v1
LOCAL_LLM_API_KEY=
LOCAL_LLM_MODEL=gpt-5.4
#
# TTS (voice of AI character) via navy — eleven_v3 gives best Russian quality:
NAVY_TTS_ENABLED=true
NAVY_TTS_MODEL=eleven_v3
NAVY_TTS_VOICE=alice
#
# Embeddings (for RAG / legal docs):
LOCAL_EMBEDDING_URL=https://api.navy/v1
LOCAL_EMBEDDING_API_KEY=
LOCAL_EMBEDDING_MODEL=text-embedding-3-large

# ── App (PRODUCTION) ─────────────────────────────────────────────────
APP_ENV=production
APP_DEBUG=false
APP_HOST=0.0.0.0
APP_PORT=8000
FRONTEND_URL=https://your-domain.com
CORS_ORIGINS=https://your-domain.com

# NEXT_PUBLIC_* are baked at build time
NEXT_PUBLIC_API_URL=https://your-domain.com/api
NEXT_PUBLIC_WS_URL=wss://your-domain.com/ws

# ── CSRF ────────────────────────────────────────────────────────────
# Generate secret: openssl rand -hex 32
CSRF_SECRET=CHANGE_ME_GENERATE_WITH_OPENSSL

# ── Logging ─────────────────────────────────────────────────────────
LOG_LEVEL=info
LOG_FORMAT=json

# ── Rate Limits (production) ─────────────────────────────────────────
MAX_SESSIONS_PER_DAY=10
MAX_SESSION_DURATION_MINUTES=30
MAX_MESSAGES_PER_SESSION=200

# ── OAuth ─────────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=https://your-domain.com/auth/callback
YANDEX_CLIENT_ID=
YANDEX_CLIENT_SECRET=
YANDEX_REDIRECT_URI=https://your-domain.com/auth/callback

# ── STT (optional) ───────────────────────────────────────────────────
WHISPER_URL=http://whisper:8000
WHISPER_MODEL=large-v3
WHISPER_LANGUAGE=ru

# ── SMTP (email for password reset) ─────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM_NAME=Hunter888
SMTP_USE_TLS=true

# ── Web Push (VAPID) ───────────────────────────────────────────────
# Generate: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@your-domain.com

# ── Backups ──────────────────────────────────────────────────────────
BACKUP_RETENTION_DAYS=30
BACKUP_PATH=/backups

# ── TZ-1 Unified Client Domain (Roadmap Phase 4) ─────────────────────
# Dual-write legacy + canonical DomainEvent journal. Keep True during
# pilot — it is the foundation of the whole roadmap. Turn off only for
# emergency rollback.
CLIENT_DOMAIN_DUAL_WRITE_ENABLED=true
# Cutover read path. Flip to true AFTER parity_ratio stays at 1.0 for
# at least 48h and the CRM UI has been verified against projection
# rows only. See /admin/client-domain dashboard.
CLIENT_DOMAIN_CUTOVER_READ_ENABLED=false
# Strictness: when true, any DomainEvent emit failure rolls the whole
# business transaction back. Keep false during pilot — emit failures
# are logged and the legacy write still commits.
CLIENT_DOMAIN_STRICT_EMIT=false

# ── Phase 1 — ConversationCompletionPolicy ──────────────────────────
# Shadow mode (false) = legacy terminal paths own side effects, policy
# only stamps canonical terminal_outcome/terminal_reason/completed_via
# columns. Strict (true) = policy becomes authoritative.
COMPLETION_POLICY_STRICT=false
# Always emit session.completed DomainEvent so observability dashboards
# can track completion cadence. Free to keep on; volume is 1 per session.
COMPLETION_POLICY_EMIT_EVENT=true

# ── Observability ────────────────────────────────────────────────────
# Put /metrics behind nginx IP allowlist before enabling in prod.
METRICS_ENABLED=false

