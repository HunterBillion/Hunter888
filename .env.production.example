# ╔══════════════════════════════════════════════════════════════════════╗
# ║  Hunter888 — Production Environment Template                        ║
# ║  Copy to .env.production and fill in all values.                    ║
# ║  NEVER commit this file with real credentials.                      ║
# ╚══════════════════════════════════════════════════════════════════════╝

# ── Database ──────────────────────────────────────────────────────────
# Generate password: openssl rand -base64 24
POSTGRES_USER=trainer
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD
POSTGRES_DB=trainer_db
DATABASE_URL=postgresql+asyncpg://${POSTGRES_USER}:${POSTGRES_PASSWORD}@postgres:5432/${POSTGRES_DB}

# ── Redis ─────────────────────────────────────────────────────────────
# Generate password: openssl rand -base64 24
REDIS_PASSWORD=CHANGE_ME_STRONG_PASSWORD
REDIS_URL=redis://:${REDIS_PASSWORD}@redis:6379/0

# ── JWT ───────────────────────────────────────────────────────────────
# Generate secret: openssl rand -hex 32
JWT_SECRET=CHANGE_ME_GENERATE_WITH_OPENSSL
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# ── LLM ──────────────────────────────────────────────────────────────
LLM_PRIMARY_MODEL=gemini-2.5-flash
LLM_FALLBACK_MODEL=gpt-4o-mini
LLM_TIMEOUT_SECONDS=15
LLM_MAX_HISTORY_MESSAGES=20
MAX_CONCURRENT_LLM_CALLS=5

# ── API Keys (store in secrets manager, inject via CI/CD) ─────────────
# Gemini: https://aistudio.google.com/apikey
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
GEMINI_EMBEDDING_API_KEY=
GEMINI_EMBEDDING_MODEL=gemini-embedding-001

# ElevenLabs TTS: https://elevenlabs.io/app/settings/api-keys
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_IDS_MALE=
ELEVENLABS_VOICE_IDS_FEMALE=
ELEVENLABS_MODEL=eleven_v3
ELEVENLABS_TIMEOUT_SECONDS=10
ELEVENLABS_ENABLED=true

# Cloud fallbacks
CLAUDE_API_KEY=
OPENAI_API_KEY=

# ── App (PRODUCTION) ─────────────────────────────────────────────────
APP_ENV=production
APP_DEBUG=false
APP_HOST=0.0.0.0
APP_PORT=8000
FRONTEND_URL=https://your-domain.com
CORS_ORIGINS=https://your-domain.com

# NEXT_PUBLIC_* are baked at build time
NEXT_PUBLIC_API_URL=https://your-domain.com/api
NEXT_PUBLIC_WS_URL=wss://your-domain.com/ws

# ── CSRF ────────────────────────────────────────────────────────────
# Generate secret: openssl rand -hex 32
CSRF_SECRET=CHANGE_ME_GENERATE_WITH_OPENSSL

# ── Logging ─────────────────────────────────────────────────────────
LOG_LEVEL=info
LOG_FORMAT=json

# ── Rate Limits (production) ─────────────────────────────────────────
MAX_SESSIONS_PER_DAY=10
MAX_SESSION_DURATION_MINUTES=30
MAX_MESSAGES_PER_SESSION=200

# ── OAuth ─────────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=https://your-domain.com/auth/callback
YANDEX_CLIENT_ID=
YANDEX_CLIENT_SECRET=
YANDEX_REDIRECT_URI=https://your-domain.com/auth/callback

# ── STT (optional) ───────────────────────────────────────────────────
WHISPER_URL=http://whisper:8000
WHISPER_MODEL=large-v3
WHISPER_LANGUAGE=ru

# ── SMTP (email for password reset) ─────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM_NAME=Hunter888
SMTP_USE_TLS=true

# ── Web Push (VAPID) ───────────────────────────────────────────────
# Generate: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@your-domain.com

# ── Backups ──────────────────────────────────────────────────────────
BACKUP_RETENTION_DAYS=30
BACKUP_PATH=/backups
